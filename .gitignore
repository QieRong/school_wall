# File: D:\桌面\biaobaiqiang\.gitignore

# ========================================================
# 1. 您提供的自定义规则 (保留并整合)
# ========================================================
tmp_result.txt
*.tmp
*.bak

# 敏感配置
**/.env.local
**/.env.*.local
**/application-local.yml
**/application-prod.yml
**/*.local.yml

# ========================================================
# 2. Spring Boot (后端) 专业过滤
# ========================================================
target/
!.mvn/wrapper/maven-wrapper.jar
*.class
*.jar
*.war
*.ear
*.log

# 排除 Maven/Gradle 运行时生成的临时文件
.mvn/
.gradle/
build/
bin/

# ========================================================
# 3. Vue.js / Node.js (前端) 专业过滤
# ========================================================
# 极其重要：这是 264MB 的主要来源
node_modules/
dist/
dist-ssr/
*.local

# 日志与缓存
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.eslintcache

# ========================================================
# 4. IDE 与 系统文件 (保持团队环境纯净)
# ========================================================
.idea/
*.iml
*.iws
.vscode/
.project
.classpath
.settings/
.DS_Store
Thumbs.db