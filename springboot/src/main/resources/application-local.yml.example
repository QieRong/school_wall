# ========================================================
# 本地开发环境覆盖配置示例
# 使用方法：复制此文件为 application-local.yml，填入真实值
# 注意：application-local.yml 已被 .gitignore 排除，不会提交到 Git 仓库
# 启动时添加 Spring Profile: --spring.profiles.active=local
# ========================================================

# DeepSeek AI 密钥（本地开发用）
# 申请地址：https://platform.deepseek.com/api_keys
deepseek:
  api-key: sk-your_deepseek_api_key_here

# 数据库配置（若与默认值不同时填写）
# spring:
#   datasource:
#     username: root
#     password: your_db_password
