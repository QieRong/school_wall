<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.BottleReplyMapper">

    <!-- 获取瓶子的回复列表（带用户信息） -->
    <select id="selectRepliesWithUser" resultType="com.example.entity.BottleReply">
        SELECT
            br.*,
            u.nickname,
            u.avatar
        FROM bottle_reply br
        LEFT JOIN sys_user u ON br.user_id = u.id
        WHERE br.bottle_id = #{bottleId}
        ORDER BY br.create_time ASC
    </select>

</mapper>
