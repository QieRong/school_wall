# ========================================================
# 本地开发环境配置示例
# 使用方法：复制此文件为 .env.local，然后填入真实的密钥值
# 注意：.env.local 已被 .gitignore 排除，不会提交到 Git 仓库
# ========================================================

# 后端 API 地址
# 本地开发使用代理（推荐）
VITE_API_URL=/api
# 或者直接连接后端
# VITE_API_URL=http://localhost:19090

# ========================================================
# 高德地图 API 配置
# 申请地址：https://console.amap.com/
# 需要开通：Web端(JS API) 服务
# ========================================================
VITE_AMAP_KEY=your_amap_key_here
VITE_AMAP_SECRET=your_amap_secret_here
